APP_NAME="TechMorah"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Logo: default img/techmorah-icon.png (icon + wordmark in file — wordmark hidden by crop)
# BRAND_LOGO=img/techmorah-icon.png
# Hide bottom N% of image (0 = no crop, for pure SVG/icon files)
# BRAND_LOGO_CROP_BOTTOM=42
# Tab / apple icon (small vector mark)
# BRAND_FAVICON=img/techmorah-logo.svg

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=techmorah
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Use "log" for local dev (emails in storage/logs) or "smtp" for real delivery (e.g. Gmail).
# Gmail: enable 2FA, create an App Password, then set MAIL_USERNAME + MAIL_PASSWORD and:
# MAIL_MAILER=smtp MAIL_HOST=smtp.gmail.com MAIL_PORT=587 MAIL_ENCRYPTION=tls
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_ENCRYPTION=null
MAIL_USERNAME=null
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="techmorahsolution@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"
# Where contact-form submissions are delivered (defaults to MAIL_FROM_ADDRESS if empty)
MAIL_CONTACT_ADDRESS=techmorahsolution@gmail.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o-mini

# Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# AI Provider Switch
AI_PROVIDER=openai

# Twilio Configuration (SMS & Voice)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=your_twilio_phone_number
TWILIO_WHATSAPP_FROM=your_whatsapp_phone_number

# Company Configuration
COMPANY_PHONE=+255139724
COMPANY_EMAIL=techmorahsolution@gmail.com
